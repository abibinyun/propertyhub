DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property

JWT_SECRET=your-secret-key-min-32-characters
JWT_EXPIRES_IN=7d
JWT_COOKIE_MAX_AGE_DAYS=7
NODE_ENV=development

APP_URL=http://localhost:3003
FRONTEND_URL=http://localhost:3002

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

EMAIL_PROVIDER=log
RESEND_API_KEY=

PAYMENT_PROVIDER=log
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Security
BCRYPT_ROUNDS=10

# Token expiry
VERIFICATION_TOKEN_EXPIRY_HOURS=24
VERIFICATION_RESEND_COOLDOWN_MINUTES=5
RESET_TOKEN_EXPIRY_HOURS=1

# Limits
LEAD_DAILY_LIMIT=10
IMAGE_MAX_SIZE_MB=5

# Featured pricing (IDR)
FEATURED_PRICE_BASIC=99000
FEATURED_PRICE_PREMIUM=299000
FEATURED_PRICE_ULTIMATE=599000
FEATURED_DURATION_BASIC_DAYS=7
FEATURED_DURATION_PREMIUM_DAYS=7
FEATURED_DURATION_ULTIMATE_DAYS=30
