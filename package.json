{
  "name": "propertyhub",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "cd apps/api && bunx prisma migrate dev",
    "db:seed": "cd apps/api && bunx prisma db seed",
    "db:studio": "cd apps/api && bunx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
